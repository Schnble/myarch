#!/bin/bash

# myarch:summary=Create or restore system snapshots with snapper
# myarch:args=<create|restore>
# myarch:requires-sudo=true

set -e

COMMAND="$1"
MYARCH_PATH=${MYARCH_PATH:-$HOME/.local/share/myarch}

if [[ -z $COMMAND ]]; then
  echo "Usage: myarch-snapshot <create|restore>" >&2
  exit 1
fi

if ! command -v snapper &>/dev/null; then
  exit 127 # myarch-update can use this to just ignore if snapper is not available
fi

case "$COMMAND" in
create)
  DESC="$(myarch-version)"

  echo -e "\e[32mCreate system snapshot\e[0m"

  # Get existing snapper config names from CSV output
  mapfile -t CONFIGS < <(sudo snapper --csvout list-configs | awk -F, 'NR>1 {print $1}')

  for config in "${CONFIGS[@]}"; do
    sudo snapper -c "$config" create -c number -d "$DESC"
    sudo snapper -c "$config" cleanup number
  done
  echo
  ;;
restore)
  sudo limine-snapper-restore
  ;;
esac
