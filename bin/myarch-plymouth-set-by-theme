#!/bin/bash

# myarch:summary=Set the Plymouth boot theme from an Myarch theme
# myarch:args=<theme-name>
# myarch:requires-sudo=true

# Resolve a theme by name and apply its unlock.png + colors.toml as the
# Plymouth boot screen via myarch-plymouth-set.

if [[ $# -ne 1 ]]; then
  echo "Usage: myarch-plymouth-set-by-theme <theme-name>" >&2
  exit 1
fi

theme=$1

if [[ -d ~/.config/myarch/themes/$theme ]]; then
  theme_dir=~/.config/myarch/themes/$theme
else
  theme_dir="$MYARCH_PATH/themes/$theme"
fi

bg=$(awk -F'"' '/^background/{print $2}' "$theme_dir/colors.toml")
text=$(awk -F'"' '/^foreground/{print $2}' "$theme_dir/colors.toml")

exec myarch-plymouth-set "$bg" "$text" "$theme_dir/unlock.png"
