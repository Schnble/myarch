#!/bin/bash

# myarch:summary=Set the Myarch channel, which dictates what git branch and package repository is used.
# myarch:args=<stable|rc|edge|dev>
# myarch:requires-sudo=true

if (($# == 0)); then
  echo "Usage: myarch-channel-set [stable|rc|edge|dev]"
  exit 1
else
  channel="$1"
fi

case "$channel" in
"stable") myarch-branch-set "master" && myarch-refresh-pacman "stable" ;;
"rc") myarch-branch-set "rc" && myarch-refresh-pacman "rc" ;;
"edge") myarch-branch-set "master" && myarch-refresh-pacman "edge" ;;
"dev") myarch-branch-set "dev" && myarch-refresh-pacman "edge" ;;
*) echo "Unknown channel: $channel"; exit 1; ;;
esac

myarch-update -y
