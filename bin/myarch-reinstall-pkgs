#!/bin/bash

# myarch:summary=Reinstall all default Myarch packages from the stable channel
# myarch:requires-sudo=true

set -e

# Reinstall all default Myarch packages from the stable channel and downgrade any packages that are too new.

# Set the package repository to the stable mirrors
myarch-refresh-pacman

# Downgrade any packages to the stable setup
sudo pacman -Suu --noconfirm

# Ensure all packages are installed
mapfile -t packages < <(grep -v '^#' "$MYARCH_PATH/install/myarch-base.packages" | grep -v '^$')
sudo pacman -Syu --noconfirm --needed "${packages[@]}"
