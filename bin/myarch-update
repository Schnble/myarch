#!/bin/bash

# myarch:summary=Update Myarch and system packages
# myarch:args=[-y]
# myarch:examples=myarch update | myarch update -y
# myarch:requires-sudo=true

set -e

# Run the update inside a PTY so pacman/yay keep showing download progress
# while still logging the full session for later analysis.
if [[ -z $MYARCH_UPDATE_LOGGED ]]; then
  script_command=$(printf '%q ' "$0" "$@")
  exec env MYARCH_UPDATE_LOGGED=1 script -qefc "$script_command" "/tmp/myarch-update.log"
fi

trap 'echo ""; echo -e "\033[0;31mSomething went wrong during the update!\n\nPlease review the output above carefully, correct the error, and retry the update.\n\nIf you need assistance, get help from the community at https://myarch.org/discord\033[0m"' ERR

if [[ $1 == "-y" ]] || myarch-update-confirm; then
  myarch-snapshot create || (($? == 127))
  myarch-update-git
  myarch-update-perform
fi
