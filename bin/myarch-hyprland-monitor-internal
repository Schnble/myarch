#!/bin/bash

# myarch:summary=Enable, disable, toggle, or recover the internal laptop display
# myarch:args=<on|off|toggle|recover>

TOGGLE="internal-monitor-disable"
TOGGLE_FLAG="$HOME/.local/state/myarch/toggles/hypr/$TOGGLE.lua"
MIRROR_TOGGLE="internal-monitor-mirror"

# Get internal monitor name dynamically
INTERNAL=$(hyprctl monitors -j | jq -r '.[] | select(.name | contains("eDP")).name' | head -n 1)

on() {
  if myarch-hyprland-toggle-enabled $TOGGLE; then
    myarch-hyprland-toggle $TOGGLE off
    myarch-notification-send -g 󰍹 "Laptop display enabled"
  fi
}

off() {
  if ! myarch-hw-external-monitors; then
    myarch-notification-send -g 󰍹 "Can't disable the only active display"
    exit 1
  fi

  if myarch-hyprland-toggle-disabled $TOGGLE && myarch-hyprland-toggle-disabled $MIRROR_TOGGLE; then
    printf 'hl.monitor({ output = "%s", disabled = true })\n' "$INTERNAL" >"$TOGGLE_FLAG"
    myarch-notification-send -g 󰍹 "Laptop display disabled"
    hyprctl reload
  fi
}

recover() {
  if ! myarch-hw-external-monitors && myarch-hyprland-toggle-enabled $TOGGLE; then
    myarch-hyprland-toggle $TOGGLE off
  fi
}

toggle() {
  if myarch-hyprland-toggle-enabled $TOGGLE; then
    on
  else
    off
  fi
}

case "$1" in
  on) on ;;
  off) off ;;
  toggle) toggle ;;
  recover) recover ;;
  *)
    echo "Usage: $(basename "$0") {on|off|toggle|recover}" >&2
    exit 1
    ;;
esac
