#!/bin/bash

# myarch:summary=Manage persistent state files for Myarch toggles and settings.
# myarch:args=<set|clear> <state-name-or-pattern>
# myarch:hidden=true

STATE_DIR="$HOME/.local/state/myarch"
mkdir -p "$STATE_DIR"

COMMAND="$1"
STATE_NAME="$2"

if [[ -z $COMMAND ]]; then
  echo "Usage: myarch-state <set|clear> <state-name-or-pattern>"
  exit 1
fi

if [[ -z $STATE_NAME ]]; then
  echo "Usage: myarch-state $COMMAND <state-name>"
  exit 1
fi

case "$COMMAND" in
set) touch "$STATE_DIR/$STATE_NAME" ;;
clear) find "$STATE_DIR" -maxdepth 1 -type f -name "$STATE_NAME" -delete ;;
esac
