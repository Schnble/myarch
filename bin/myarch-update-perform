#!/bin/bash

# myarch:summary=Run the full Myarch update pipeline
# myarch:requires-sudo=true

set -e

# Ensure screensaver/sleep doesn't set in during updates
hyprctl dispatch 'hl.dsp.window.tag({ tag = "+noidle" })' &>/dev/null || hyprctl dispatch tagwindow +noidle &>/dev/null || true

# Perform all update steps
myarch-update-keyring
myarch-update-available-reset
myarch-update-system-pkgs
myarch-migrate
myarch-update-aur-pkgs
myarch-update-orphan-pkgs
myarch-hook post-update

myarch-update-analyze-logs

myarch-update-restart

# Re-enable screensaver/sleep after updates
hyprctl dispatch 'hl.dsp.window.tag({ tag = "-noidle" })' &>/dev/null || hyprctl dispatch tagwindow -- -noidle &>/dev/null || true
