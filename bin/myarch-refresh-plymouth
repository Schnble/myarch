#!/bin/bash

# myarch:summary=Overwrite the user config for the Plymouth drive decryption and boot sequence with the Myarch default and rebuild it.
# myarch:requires-sudo=true

sudo cp -r ~/.local/share/myarch/default/plymouth/* /usr/share/plymouth/themes/myarch/
sudo plymouth-set-default-theme myarch

if command -v limine-mkinitcpio &>/dev/null; then
  sudo limine-mkinitcpio
else
  sudo mkinitcpio -P
fi
