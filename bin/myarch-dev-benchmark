#!/bin/bash

# myarch:summary=Measure Myarch CLI response times
# myarch:args=[--repeat=<count>]
# myarch:examples=myarch dev benchmark | myarch dev benchmark --repeat=10

set -euo pipefail

MYARCH_BIN_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
CLI="$MYARCH_BIN_DIR/myarch"
REPEAT=5

show_help() {
  cat <<'EOF'
Usage:
  myarch dev benchmark [--repeat=<count>]

Measure response times for common Myarch CLI surfaces.

Options:
  --repeat=<count>  Number of times to run each case (default: 5)
EOF
}

now_us() {
  local now="${EPOCHREALTIME/./}"
  printf '%s' "$now"
}

format_ms() {
  local us="$1"
  printf '%d.%03d' "$(( us / 1000 ))" "$(( us % 1000 ))"
}

run_case() {
  local label="$1"
  shift
  local total_us=0
  local min_us=0
  local max_us=0
  local elapsed_us=0
  local start_us=0
  local end_us=0
  local status=0

  for (( i = 1; i <= REPEAT; i++ )); do
    start_us=$(now_us)
    if "$@" >/dev/null; then
      status=0
    else
      status=$?
    fi
    end_us=$(now_us)

    if (( status != 0 )); then
      printf '%-34s failed (exit %d)\n' "$label" "$status"
      return "$status"
    fi

    elapsed_us=$(( end_us - start_us ))
    total_us=$(( total_us + elapsed_us ))

    if (( i == 1 || elapsed_us < min_us )); then
      min_us=$elapsed_us
    fi

    if (( elapsed_us > max_us )); then
      max_us=$elapsed_us
    fi
  done

  printf '%-34s avg %8s ms  min %8s ms  max %8s ms\n' \
    "$label" \
    "$(format_ms "$(( total_us / REPEAT ))")" \
    "$(format_ms "$min_us")" \
    "$(format_ms "$max_us")"
}

while (( $# > 0 )); do
  case "$1" in
  --repeat=*)
    REPEAT="${1#*=}"
    ;;
  --help | -h)
    show_help
    exit 0
    ;;
  *)
    echo "Unknown option: $1" >&2
    show_help >&2
    exit 2
    ;;
  esac
  shift
done

if [[ ! $REPEAT =~ ^[0-9]+$ ]] || (( REPEAT < 1 )); then
  echo "--repeat must be a positive integer" >&2
  exit 2
fi

printf 'Myarch CLI benchmark (%d runs each)\n\n' "$REPEAT"
run_case "myarch" "$CLI"
run_case "myarch --help" "$CLI" --help
run_case "myarch commands" "$CLI" commands
run_case "myarch commands --json" "$CLI" commands --json
run_case "myarch commands --all --json" "$CLI" commands --all --json
run_case "myarch theme set --help" "$CLI" theme set --help
run_case "myarch screenshot --help" "$CLI" screenshot --help
run_case "myarch restart --help" "$CLI" restart --help
run_case "myarch theme current" "$CLI" theme current
