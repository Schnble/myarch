#!/bin/bash

# myarch:summary=Log out after closing application windows
# myarch:examples=myarch logout | myarch system logout
# myarch:aliases=myarch logout

nohup bash -c "sleep 2 && uwsm stop" >/dev/null 2>&1 &

# Now close all windows
myarch-hyprland-window-close-all
sleep 1 # Allow apps like Chrome to shutdown correctly
