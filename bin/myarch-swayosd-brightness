#!/bin/bash

# myarch:summary=Display brightness level using SwayOSD on the current monitor.
# myarch:args=<0-100>
# myarch:examples=myarch swayosd brightness 0 | myarch swayosd brightness 50 | myarch swayosd brightness 100

percent="$1"

progress="$(awk -v p="$percent" 'BEGIN{printf "%.2f", p/100}')"
[[ $progress == "0.00" ]] && progress="0.01"

myarch-swayosd-client \
  --custom-icon display-brightness-symbolic \
  --custom-progress "$progress" \
  --custom-progress-text "$(printf '%3d%%' "$percent")"
