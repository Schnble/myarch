#!/bin/bash

# myarch:summary=Creates a new Myarch migration named after the unix timestamp of the last commit.

cd ~/.local/share/myarch
migration_file="$HOME/.local/share/myarch/migrations/$(git log -1 --format=%cd --date=unix).sh"
touch $migration_file

if [[ $1 != "--no-edit" ]]; then
  nvim $migration_file
fi

echo $migration_file
