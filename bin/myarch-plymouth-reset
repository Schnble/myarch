#!/bin/bash

# myarch:summary=Restore the default Myarch Plymouth boot theme and SDDM login screen
# myarch:requires-sudo=true

theme_dir="/usr/share/plymouth/themes/myarch"

sudo find ~/.local/share/myarch/default/plymouth -maxdepth 1 -type f -exec cp -t "$theme_dir/" {} +
sudo plymouth-set-default-theme myarch

if myarch-cmd-present limine-mkinitcpio; then
  sudo limine-mkinitcpio
else
  sudo mkinitcpio -P
fi

myarch-refresh-sddm
