#!/bin/bash

# myarch:summary=Set the branch for Myarch's git repository.
# myarch:args=<master|rc|dev>

if (($# == 0)); then
  echo "Usage: myarch-branch-set [master|rc|dev]"
  exit 1
else
  branch="$1"
fi

if [[ $branch != "master" && $branch != "rc" && $branch != "dev" ]]; then
  echo "Error: Invalid branch '$branch'. Must be one of: master, rc, dev"
  exit 1
fi

git -C $MYARCH_PATH switch $branch
