#!/bin/bash

# myarch:summary=Launch or focus on a given web app identified by the window-pattern.
# myarch:args=<window-pattern> <url-and-flags...>

if (($# == 0)); then
  echo "Usage: myarch-launch-or-focus-webapp [window-pattern] [url-and-flags...]"
  exit 1
fi

WINDOW_PATTERN="$1"
shift
LAUNCH_COMMAND="myarch-launch-webapp $@"

exec myarch-launch-or-focus "$WINDOW_PATTERN" "$LAUNCH_COMMAND"
