#!/bin/bash

# myarch:summary=Reinstall Myarch packages and reset default configs
# myarch:requires-sudo=true

set -e

# Attempt to reinstall all default Myarch packages and reset all the default configs.

echo -e "This will reinstall all the default Myarch packages and reset all default configs.\nWarning: All user changes to configs will be lost.\n"

if gum confirm "Are you sure you want to reinstall and lose all config changes?"; then
  myarch-reinstall-git
  myarch-reinstall-pkgs
  myarch-reinstall-configs

  gum confirm "System has been reinstalled. Reboot?" && myarch-system-reboot
fi
